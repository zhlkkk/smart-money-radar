# Smart Money Radar backend environment
# Copy to .env for local backend development.

# === Core webhook pipeline ===
HELIUS_AUTH_TOKEN=Bearer your-secret-here
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL=claude-haiku-4-5-20251001
PORT=3000
NODE_ENV=development
SENTRY_DSN=

# === Wallet discovery ===
# HELIUS_API_KEY manages webhook addresses; HELIUS_AUTH_TOKEN validates incoming webhook calls.
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
BIRDEYE_API_KEY=
DISCOVERY_INTERVAL_MS=21600000
DISCOVERY_WALLET_CAP=30

# === Database and backend API ===
DATABASE_POOL_URL=
BACKEND_API_KEY=dev-shared-secret

# === Paddle Billing ===
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
PADDLE_ENVIRONMENT=sandbox
APP_URL=http://localhost:3001

# === Helio Pay ===
HELIO_WEBHOOK_SHARED_TOKEN=

# === Clerk backend integration ===
CLERK_SECRET_KEY=

# === Telegram bot webhook and channel access ===
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_INVITE_LINK=

# === Admin backtest API ===
ADMIN_API_KEY=
